#include <bits/stdc++.h>
using namespace std;
int addOne(vector<int>& arr) {
        // code here
    int n=arr.size();
    int m=0;
    for(int i=0;i<n;i++){
        int k=arr[i];
         m=(pow(10,(n-i-1))*k+m);
    
        
    }
    return m+1;
    
}
int main() {
    vector<int> arr={1,2,3};
    
	cout<<addOne(arr);

}
